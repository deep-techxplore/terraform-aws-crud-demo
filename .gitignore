target/
*.class
!.mvn/wrapper/maven-wrapper.jar

# ============================ Terraform ===============================
# Local provider plugins / cache
.terraform/
# State files — CONTAIN SECRETS (db password, etc). Never commit.
*.tfstate
*.tfstate.*
