{
  "info": {
    "name": "Document Management Service",
    "description": "Sample requests for the Document Management Service API (v1).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "documentId",
      "value": "REPLACE_WITH_DOCUMENT_ID"
    }
  ],
  "item": [
    {
      "name": "Create Document Metadata",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Q2 Financial Report\",\n  \"description\": \"Quarterly financials for FY26\",\n  \"category\": \"FINANCE\",\n  \"uploadedBy\": \"vikas\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents"]
        }
      }
    },
    {
      "name": "Get Document By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}"]
        }
      }
    },
    {
      "name": "Get All Documents (paged/sorted/filtered)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents?page=0&size=10&sortBy=createdAt&sortDir=desc&category=FINANCE",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" },
            { "key": "sortBy", "value": "createdAt" },
            { "key": "sortDir", "value": "desc" },
            { "key": "category", "value": "FINANCE" }
          ]
        }
      }
    },
    {
      "name": "Update Document",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Q2 Financial Report (Revised)\",\n  \"description\": \"Revised quarterly financials\",\n  \"category\": \"FINANCE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}"]
        }
      }
    },
    {
      "name": "Delete Document (soft)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}"]
        }
      }
    },
    {
      "name": "Upload File To S3",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/upload",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}", "upload"]
        }
      }
    },
    {
      "name": "Download File From S3",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/download",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "documents", "{{documentId}}", "download"]
        }
      }
    }
  ]
}
